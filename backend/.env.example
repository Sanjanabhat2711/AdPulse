# =====================================================
# AdPulse Backend - API Configuration TEMPLATE
# =====================================================
# 1. Copy this file to .env 
# 2. Replace ALL values with your REAL keys/tokens
# 3. Add .env to .gitignore (never commit real keys)
# =====================================================

# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-key-here

# Hugging Face Token (https://huggingface.co/settings/tokens) 
HF_TOKEN=hf_your-token-here

# Google Cloud Vision Service Account (path to JSON key file)
GOOGLE_APPLICATION_CREDENTIALS=keys/google-vision-key.json